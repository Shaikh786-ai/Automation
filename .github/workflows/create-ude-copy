name: Create UDE (OIDC, no secrets)

on:
  workflow_dispatch   # You can switch to push if you want auto execution

permissions:
  id-token: write
  contents: read

jobs:
  create-ude:
    runs-on: ubuntu-latest

    env:
      ENV_NAME: "ude-dev01"
      ENV_TYPE: "Sandbox"
      REGION: "india"
      CURRENCY: "USD"
      LANGUAGE: "1033"
      DOMAIN_NAME: "ude-dev01"

    steps:
      - uses: actions/checkout@v4

      # Install Power Platform CLI actions
      - uses: microsoft/powerplatform-actions/actions-install@v1

      # Create environment using OIDC (no client secret)
      - name: Create UDE environment
        uses: microsoft/powerplatform-actions/create-environment@v1
        with:
          app-id: ${{ secrets.PP_CLIENT_ID }}
          tenant-id: ${{ secrets.PP_TENANT_ID }}

          # Hardcoded values from env
          name: ${{ env.ENV_NAME }}
          environment-type: ${{ env.ENV_TYPE }}
          region: ${{ env.REGION }}
          currency: ${{ env.CURRENCY }}
          language: ${{ env.LANGUAGE }}
          domain-name: ${{ env.DOMAIN_NAME }}

      - name: Done
        run: echo "UDE environment created successfully."
